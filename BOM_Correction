def create_gui():
    NAVY   = "#1B2A4A"
    TEAL   = "#1E6E6E"
    ACCENT = "#E8A838"
    BG     = "#F0F4F8"
    WHITE  = "#FFFFFF"
    GREY   = "#7A8A99"
    DARK   = "#2C3E50"

    root = tk.Tk()
    root.title("BOM Combined Processor  v2.0")
    root.configure(bg=BG)
    root.geometry("720x680")
    root.resizable(False, False)
    root.lift()
    root.attributes('-topmost', True)
    root.after(1200, lambda: root.attributes('-topmost', False))

    # ── HEADER ──────────────────────────────────────────
    hdr = tk.Frame(root, bg=NAVY, height=72)
    hdr.pack(fill=tk.X)
    hdr.pack_propagate(False)

    tk.Label(hdr, text="BOM Combined Processor",
             font=("Montserrat", 18, "bold"), bg=NAVY, fg=WHITE
             ).pack(side=tk.LEFT, padx=22, pady=16)
    tk.Label(hdr, text="v2.0",
             font=("Montserrat", 10), bg=NAVY, fg=ACCENT
             ).pack(side=tk.LEFT, pady=22)

    # ── BODY ────────────────────────────────────────────
    body = tk.Frame(root, bg=BG)
    body.pack(fill=tk.BOTH, expand=True, padx=22, pady=14)

    # ── STEPS PANEL ─────────────────────────────────────
    sf = tk.LabelFrame(body, text="  Processing Steps  ",
                       bg=BG, fg=TEAL,
                       font=("Montserrat", 9, "bold"),
                       bd=1, relief=tk.GROOVE, padx=8, pady=6)
    sf.pack(fill=tk.X, pady=(0, 10))

    steps = [
        ("0", "Generate Hierarchy & Level from Part Code indentation"),
        ("1", "Move Thickness from Sheet rows to row above  (warns if mismatch)"),
        ("2", "Auto-fill Thickness from Part Code -- BE/FL: value after 'T'  e.g. BE-MS-T1.6 -> 1.6"),
        ("3", "Delete Sheet rows  |  Delete empty Part Code rows"),
        ("4", "Delete partial data rows where Total Weight = 0"),
        ("5", "Qty Explosion — multiply quantities down through hierarchy"),
        ("6", "Process Assignment: FL=Laser  BE=Laser+Bend  PL=Plasma  SAW=Saw"),
    ]
    for num, text in steps:
        rf = tk.Frame(sf, bg=BG)
        rf.pack(fill=tk.X, pady=1)
        tk.Label(rf, text=f" {num} ", bg=TEAL, fg=WHITE,
                 font=("Montserrat", 8, "bold")).pack(side=tk.LEFT, padx=(0, 7))
        tk.Label(rf, text=text, bg=BG, fg=DARK,
                 font=("Montserrat", 9), anchor='w').pack(side=tk.LEFT)

    # ── FILE SELECTION ───────────────────────────────────
    ff = tk.LabelFrame(body, text="  Input File  ",
                       bg=BG, fg=TEAL,
                       font=("Montserrat", 9, "bold"),
                       bd=1, relief=tk.GROOVE, padx=10, pady=8)
    ff.pack(fill=tk.X, pady=(0, 10))

    fi = tk.Frame(ff, bg=BG)
    fi.pack(fill=tk.X)

    file_entry = tk.Entry(fi, width=62, font=("Montserrat", 9),
                          bg=WHITE, relief=tk.FLAT,
                          highlightthickness=1, highlightbackground="#CCCCCC")
    file_entry.pack(side=tk.LEFT, padx=(0, 8), ipady=5)

    def browse():
        fn = filedialog.askopenfilename(
            title="Select BOM Excel File",
            filetypes=[("Excel Files", "*.xlsx *.xls"), ("All Files", "*.*")])
        if fn:
            file_entry.delete(0, tk.END)
            file_entry.insert(0, fn)

    brbtn = tk.Button(fi, text="Browse...", command=browse,
                      bg=ACCENT, fg=NAVY, font=("Montserrat", 9, "bold"),
                      relief=tk.FLAT, cursor="hand2", padx=12, pady=5)
    brbtn.pack(side=tk.LEFT)
    brbtn.bind("<Enter>", lambda e: brbtn.config(bg="#D4932A"))
    brbtn.bind("<Leave>", lambda e: brbtn.config(bg=ACCENT))

    # ── PROJECT PARAMETERS ───────────────────────────────
    pf = tk.LabelFrame(body, text="  Project Parameters  ",
                       bg=BG, fg=TEAL,
                       font=("Montserrat", 9, "bold"),
                       bd=1, relief=tk.GROOVE, padx=10, pady=8)
    pf.pack(fill=tk.X, pady=(0, 10))

    def field(parent, lbl, default, row, col):
        tk.Label(parent, text=lbl, bg=BG, fg="#444444",
                 font=("Montserrat", 9), anchor='e', width=15
                 ).grid(row=row, column=col*2, padx=(8, 4), pady=5, sticky='e')
        e = tk.Entry(parent, width=22, font=("Montserrat", 9),
                     bg=WHITE, relief=tk.FLAT,
                     highlightthickness=1, highlightbackground="#CCCCCC")
        e.insert(0, str(default))
        e.grid(row=row, column=col*2+1, padx=(0, 12), pady=5, ipady=4)
        return e

    proj_e = field(pf, "Project Code :", "NA910",  0, 0)
    des_e  = field(pf, "Designer :",     "Akshay", 0, 1)
    rev_e  = field(pf, "Revision :",     "R00",    1, 0)
    qty_e  = field(pf, "Project Qty :",  "1",      1, 1)

    # ── PROGRESS ─────────────────────────────────────────
    pgf = tk.Frame(body, bg=BG)
    pgf.pack(fill=tk.X, pady=(4, 0))

    style = ttk.Style()
    style.theme_use('clam')
    style.configure("BOM.Horizontal.TProgressbar",
                    troughcolor="#D0D8E4",
                    background=TEAL,
                    thickness=16)

    progress_bar = ttk.Progressbar(pgf, length=676, mode='determinate',
                                   style="BOM.Horizontal.TProgressbar")
    progress_bar.pack(pady=(6, 3))

    status_lbl = tk.Label(body, text="Ready — select a file and press  ▶ START",
                          bg=BG, fg=GREY, font=("Montserrat", 9, "italic"))
    status_lbl.pack(pady=(2, 8))

    # ── START BUTTON ─────────────────────────────────────
    def start():
        fp = file_entry.get().strip()
        if not fp:
            messagebox.showerror("Missing File", "Please select an Excel file first.")
            return
        if not os.path.exists(fp):
            messagebox.showerror("File Not Found", f"File not found:\n{fp}")
            return
        try:
            qty_val = float(qty_e.get())
            if qty_val <= 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Invalid Qty", "Project Qty must be a positive number.")
            return

        progress_bar["value"] = 0
        status_lbl.config(text="Processing …", fg=TEAL)
        root.update()

        threading.Thread(
            target=process_file,
            args=(fp, proj_e.get().strip(), des_e.get().strip(),
                  rev_e.get().strip(), qty_val,
                  progress_bar, root, status_lbl),
            daemon=True
        ).start()

    btn_row = tk.Frame(body, bg=BG)
    btn_row.pack(pady=4)

    start_btn = tk.Button(btn_row, text="▶   START PROCESSING",
                          command=start,
                          bg=TEAL, fg=WHITE,
                          font=("Montserrat", 12, "bold"),
                          relief=tk.FLAT, cursor="hand2",
                          padx=44, pady=11)
    start_btn.pack()
    start_btn.bind("<Enter>", lambda e: start_btn.config(bg=NAVY))
    start_btn.bind("<Leave>", lambda e: start_btn.config(bg=TEAL))

    # ── FOOTER ───────────────────────────────────────────
    ftr = tk.Frame(root, bg=NAVY, height=28)
    ftr.pack(fill=tk.X, side=tk.BOTTOM)
    ftr.pack_propagate(False)
    tk.Label(ftr,
             text="Check terminal for step-by-step log  |  BOM Combined Processor v2.0  |  Developed By: Mahesh Arvind Chavan",
             bg=NAVY, fg=GREY, font=("Montserrat", 9)
             ).pack(pady=6)

    root.mainloop()


